# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Model Selection
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-pro
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OLLAMA_MODEL=llama3.2

# VibeVoice TTS Configuration
VIBEVOICE_DEVICE=cuda:0

# Output Settings
OUTPUT_FORMAT=ep3
MP3_BITRATE=128

# VLM (Vision Language Model) for figure descriptions
VLM_ENABLED=false
